# Copy to .env and fill in, or configure everything through the web UI
# (values entered in the UI are stored in config/config.json, which is gitignored).
# Environment variables override config file values.

# --- Exchange selection: binance | etoro ---
EXCHANGE=binance

# --- Binance API (create keys with "Enable Reading" + "Enable Spot & Margin Trading",
#     restrict to your IP, and DO NOT enable withdrawals) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- eToro API (subscription + user key from https://api-portal.etoro.com) ---
ETORO_API_KEY=
ETORO_USER_KEY=

# --- LLM providers (primary: Anthropic, fallback: OpenAI) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Optional SMS alerts via sipgate ---
SMS_AUTH_TOKEN=
SMS_RECIPIENT=

# --- Safety: keep true until you have verified behaviour ---
DRY_RUN=true

# --- Web UI ---
WEB_HOST=0.0.0.0
WEB_PORT=8000
